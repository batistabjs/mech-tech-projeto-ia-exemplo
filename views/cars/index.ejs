<%- include('../partials/header') %>
<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <h2>Lista de Carros</h2>
    <a href="/cars/create" class="btn">+ Novo Carro</a>
  </div>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Cliente</th>
        <th>Marca</th>
        <th>Modelo</th>
        <th>Ano</th>
        <th>Placa</th>
      </tr>
    </thead>
    <tbody>
      <% if (cars.length === 0) { %>
        <tr>
          <td colspan="6" style="text-align: center;">Nenhum carro cadastrado.</td>
        </tr>
      <% } else { %>
        <% cars.forEach(car => { %>
          <tr>
            <td>#<%= car.id %></td>
            <td><%= car.clientName %></td>
            <td><%= car.brand %></td>
            <td><strong><%= car.model %></strong></td>
            <td><%= car.year %></td>
            <td><%= car.plate %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
