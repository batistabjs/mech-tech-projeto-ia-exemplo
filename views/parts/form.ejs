<%- include('../partials/header') %>
<div class="card">
  <h2>Cadastrar Peça</h2>
  
  <form action="/parts/create" method="POST">
    <label for="name">Nome da Peça</label>
    <input type="text" id="name" name="name" placeholder="Ex: Filtro de Óleo" required>
    
    <label for="price">Preço Unitário (R$)</label>
    <input type="number" id="price" name="price" step="0.01" min="0" placeholder="45.00" required>
    
    <label for="stock">Quantidade em Estoque</label>
    <input type="number" id="stock" name="stock" min="0" placeholder="20" required>
    
    <div style="margin-top: 1rem;">
      <button type="submit" class="btn">Salvar Peça</button>
      <a href="/parts" class="btn" style="background-color: #6c757d; margin-left: 0.5rem;">Cancelar</a>
    </div>
  </form>
</div>
<%- include('../partials/footer') %>
